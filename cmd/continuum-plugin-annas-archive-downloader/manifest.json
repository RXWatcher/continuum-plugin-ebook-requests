{
  "plugin_id": "continuum.annas-archive-downloader",
  "version": "1.0.0",
  "checksum": "1250f06209dc3fbfffe6bf2b475003cc8f49f8e64f1b75faeb2e1e22c93ed38e",
  "continuum_api_version": "v1",
  "supported_platforms": [
    {
      "os": "linux",
      "arch": "amd64"
    }
  ],
  "capabilities": [
    {
      "type": "http_routes.v1",
      "id": "backend",
      "display_name": "Anna's Archive Downloader API",
      "description": "Download-provider API for Anna's Archive style search, fetch, and request forwarding."
    },
    {
      "type": "event_consumer.v1",
      "id": "request_handler",
      "display_name": "Request handler",
      "description": "Forwards ebook request_submitted events to Anna's Archive download jobs.",
      "subscriptions": [
        "plugin.continuum.ebooks.request_submitted"
      ]
    },
    {
      "type": "ebook_backend.v1",
      "id": "default",
      "display_name": "Anna's Archive Downloader",
      "description": "Request/download provider backed by an Anna's Archive download service; not a presentation library source.",
      "metadata": {
        "ebook_roles": [
          "download_provider"
        ],
        "supports_catalog": false,
        "supports_requests": true,
        "supports_auto_monitoring": false
      }
    },
    {
      "type": "scheduled_task.v1",
      "id": "reconciler",
      "display_name": "Reconcile Anna's Archive download status",
      "description": "Polls the upstream Anna's Archive download service for status changes on non-terminal downloads.",
      "cron": "*/1 * * * *"
    }
  ],
  "http_routes": [
    {
      "id": "api",
      "method": "*",
      "path": "/api/v1/*",
      "access": "authenticated"
    }
  ],
  "global_config_schema": [
    {
      "key": "database_url",
      "title": "Postgres connection string",
      "description": "DSN for the dedicated Anna's Archive downloader schema.",
      "json_schema": "{\"type\":\"object\",\"properties\":{\"value\":{\"type\":\"string\"}},\"required\":[\"value\"]}",
      "required": true,
      "admin_form": {
        "fields": [
          {
            "key": "value",
            "label": "Connection URL",
            "control": "ADMIN_FORM_CONTROL_PASSWORD",
            "required": true,
            "secret": true
          }
        ]
      }
    },
    {
      "key": "base_url",
      "title": "Anna's Archive downloader base URL",
      "description": "Base URL for the upstream downloader service, e.g. https://downloads.example.com (no trailing slash).",
      "json_schema": "{\"type\":\"object\",\"properties\":{\"value\":{\"type\":\"string\"}},\"required\":[\"value\"]}",
      "required": true,
      "admin_form": {
        "fields": [
          {
            "key": "value",
            "label": "URL",
            "control": "ADMIN_FORM_CONTROL_TEXT",
            "required": true
          }
        ]
      }
    },
    {
      "key": "api_key",
      "title": "Downloader API key",
      "description": "X-API-Key header for upstream calls.",
      "json_schema": "{\"type\":\"object\",\"properties\":{\"value\":{\"type\":\"string\"}},\"required\":[\"value\"]}",
      "required": true,
      "admin_form": {
        "fields": [
          {
            "key": "value",
            "label": "API key",
            "control": "ADMIN_FORM_CONTROL_PASSWORD",
            "required": true,
            "secret": true
          }
        ]
      }
    },
    {
      "key": "default_cover_size",
      "title": "Default cover size",
      "json_schema": "{\"type\":\"object\",\"properties\":{\"value\":{\"type\":\"string\"}}}",
      "admin_form": {
        "fields": [
          {
            "key": "value",
            "label": "Cover size",
            "control": "ADMIN_FORM_CONTROL_TEXT"
          }
        ]
      }
    },
    {
      "key": "external_source_priority",
      "title": "External source priority (ordered list)",
      "description": "JSON array — ordered indexer list passed to the upstream downloader external_search endpoint.",
      "json_schema": "{\"type\":\"object\",\"properties\":{\"value\":{\"type\":\"array\",\"items\":{\"type\":\"string\"}}}}",
      "admin_form": {
        "fields": [
          {
            "key": "value",
            "label": "Priority list (JSON array)",
            "control": "ADMIN_FORM_CONTROL_TEXT"
          }
        ]
      }
    }
  ]
}
